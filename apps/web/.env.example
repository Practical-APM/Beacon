# Beacon Web — Vercel / production environment variables
# Copy values into the Vercel project dashboard (Settings → Environment Variables).

# Required in production (Clerk auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Required — public URLs (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app

# Optional Clerk redirects (defaults match apps/web routes if omitted)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/select-org
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/select-org
