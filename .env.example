# =============================================================================
# Beacon — Environment Variables
# Copy to .env and adjust for local development
# NEVER commit .env to version control
# =============================================================================

# --- Shared ---
NODE_ENV=development
LOG_LEVEL=info

# --- Database (matches docker-compose.yml host ports) ---
# Uses 5433 on the host to avoid conflicts with other local Postgres on 5432
DATABASE_URL=postgres://beacon:beacon@localhost:5433/beacon

# --- Redis (matches docker-compose.yml host ports) ---
# Uses 6380 on the host to avoid conflicts with other local Redis on 6379
REDIS_URL=redis://localhost:6380

# --- API (apps/api) ---
PORT=3001
CORS_ORIGIN=http://localhost:3000
OTEL_ENABLED=false
OTEL_SERVICE_NAME=beacon-api

# --- Web (apps/web) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Auth (Sprint 1) ---
# Leave blank locally to enable dev auth (Bearer dev:<user-id>)
# CLERK_SECRET_KEY=
# CLERK_WEBHOOK_SECRET=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# AUTH_DEV_MODE=true

# --- LLM (Sprint 9) ---
# OPENAI_API_KEY=

# --- Integrations (Sprint 3+) ---
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# SALESFORCE_REDIRECT_URI=http://localhost:3001/v1/integrations/salesforce/callback
# INTEGRATION_ENCRYPTION_KEY=dev-only-integration-encryption-key-32b
# EVENT_WORKERS_ENABLED=true
# JIRA_CLIENT_ID=
# JIRA_CLIENT_SECRET=
# JIRA_REDIRECT_URI=http://localhost:3001/v1/integrations/jira/callback
# JIRA_WEBHOOK_SECRET=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_REDIRECT_URI=http://localhost:3001/v1/integrations/slack/callback
# SLACK_SIGNING_SECRET=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Google Calendar (Sprint 15) ---
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/v1/integrations/google-calendar/callback

# --- HubSpot CRM ---
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# HUBSPOT_REDIRECT_URI=http://localhost:3001/v1/integrations/hubspot/callback

# --- Microsoft Dynamics 365 CRM ---
# DYNAMICS_CLIENT_ID=
# DYNAMICS_CLIENT_SECRET=
# DYNAMICS_REDIRECT_URI=http://localhost:3001/v1/integrations/microsoft-dynamics/callback
# DYNAMICS_TENANT_ID=organizations

# --- Pipedrive CRM ---
# PIPEDRIVE_CLIENT_ID=
# PIPEDRIVE_CLIENT_SECRET=
# PIPEDRIVE_REDIRECT_URI=http://localhost:3001/v1/integrations/pipedrive/callback

# --- Linear work management ---
# LINEAR_CLIENT_ID=
# LINEAR_CLIENT_SECRET=
# LINEAR_REDIRECT_URI=http://localhost:3001/v1/integrations/linear/callback

# --- Outbound Webhooks (Sprint 16) ---
# FEATURE_OUTBOUND_WEBHOOKS_ENABLED=true

# --- Notifications (Sprint 13) ---
NOTIFICATION_SCHEDULER_ENABLED=true
# NOTIFICATIONS_INTERNAL_SLACK_WEBHOOK_URL=
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Beacon <notifications@yourdomain.com>

# --- Hardening / Feature flags (Sprint 14) ---
FEATURE_LLM_ENABLED=true
FEATURE_SLACK_ALERTS_ENABLED=true
